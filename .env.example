# Required: Admin secret for authentication (min 16 characters recommended)
ADMIN_SECRET=your-strong-secret-here

# Optional: GitHub API persistence (recommended for production on Vercel)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=your-username/formdocs
# GITHUB_BRANCH=main

# Optional: Vercel Blob storage (alternative to GitHub API)
# VERCEL_BLOB_TOKEN=vercel_blob_xxxxxxxxxxxxxxxxxxxx

# Optional: Base URL for generating shareable form links
# NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# Optional: Upstash Redis for persistent rate limiting
# UPSTASH_REDIS_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Optional: ISR revalidation period in seconds (Git strategy)
# REVALIDATE_SECONDS=60
